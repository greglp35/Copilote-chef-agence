# FleetOS / Supabase (front)
# Ne jamais committer de clés de service role côté front.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Fallback contexte legacy (temporaire pendant migration)
# true = autorise la lecture locale de fleetos_user_context si Supabase indisponible
# false = Supabase only
VITE_ENABLE_LEGACY_CONTEXT_FALLBACK=true

# Fallback localStorage métier (missions/tournees/tournee_missions/drivers/vehicles)
# true = fallback autorisé temporairement ; false = Supabase only
VITE_ENABLE_LEGACY_BUSINESS_LOCALSTORAGE=true

# Active les abonnements realtime FleetOS
VITE_ENABLE_FLEETOS_REALTIME=true
